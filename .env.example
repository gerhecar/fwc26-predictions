# App URL — required for link generation
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# MySQL Database — required
# DB_* vars consumed by the Next.js app code
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<MYSQL_ROOT_PASSWORD>
DB_NAME=fwc26

# MYSQL_* vars consumed by the MySQL Docker container
MYSQL_ROOT_PASSWORD=<MYSQL_ROOT_PASSWORD>
MYSQL_DATABASE=fwc26

# MYSQL_* legacy — keep for backward compat with scripts and pool.ts
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=<MYSQL_ROOT_PASSWORD>

# JWT Secret — required in production, change from default
JWT_SECRET=<JWT_SECRET>

# SMTP (optional — for email notifications)
SMTP_HOST=<SMTP_HOST>
SMTP_PORT=587
SMTP_USER=<SMTP_USER>
SMTP_PASS=<SMTP_PASSWORD>

# Admin (optional — override default admin password in seed)
ADMIN_PASSWORD=<ADMIN_PASSWORD>
